# Deployment env. Copy to `.env` next to podman-compose.yml and edit. (.env is gitignored.)

# Allowed browser origins for CORS (comma-separated). "*" is fine for read-only public data;
# set your frontend origin(s) once you add auth/write endpoints, e.g.:
#   CORS_ALLOW_ORIGINS=https://evflow.vercel.app,https://www.evflow.id
CORS_ALLOW_ORIGINS=*

# uvicorn workers (each holds its own in-memory dataset; 2 is plenty for a 2 GB VPS).
WEB_CONCURRENCY=2
