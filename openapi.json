                }
              }
            }
          }
        }
      }
    },
    "/api/v1/stats": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Aggregate statistics",
        "operationId": "stats_api_v1_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Stats"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sources": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Sources with counts",
        "operationId": "sources_api_v1_sources_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SourceCount"
                  },
                  "type": "array",
                  "title": "Response Sources Api V1 Sources Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/provinces": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Provinces with counts (filter dropdown)",
        "operationId": "provinces_api_v1_provinces_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/NameCount"
                  },
                  "type": "array",
                  "title": "Response Provinces Api V1 Provinces Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/cities": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Cities with counts (optionally within a province)",
        "operationId": "cities_api_v1_cities_get",
        "parameters": [
          {
            "name": "province",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Restrict to one province.",
              "title": "Province"
            },
            "description": "Restrict to one province."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/NameCount"
                  },
                  "title": "Response Cities Api V1 Cities Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "GeoJSONFeatureCollection": {
        "properties": {
          "type": {
            "type": "string",
            "title": "Type",
            "default": "FeatureCollection",
            "examples": [
              "FeatureCollection"
            ]
          },
          "features": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Features"
          }
        },
        "type": "object",
        "required": [
          "features"
        ],
        "title": "GeoJSONFeatureCollection",
        "description": "RFC 7946 FeatureCollection — drop straight into Leaflet/Mapbox."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Health": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status",
            "examples": [
              "ok"
            ]
          },
          "stations_loaded": {
            "type": "integer",
            "title": "Stations Loaded",
            "examples": [
              3569
            ]
          },
          "version": {
            "type": "string",
            "title": "Version",
            "examples": [
              "1.0.0"
            ]
          }
        },
        "type": "object",
        "required": [
          "status",
          "stations_loaded",
          "version"
        ],
        "title": "Health"
      },
      "NameCount": {
        "properties": {
          "name": {
            "type": "string",
            "title": "Name",
            "examples": [
              "DKI Jakarta"
            ]
          },
          "count": {
            "type": "integer",
            "title": "Count",
            "examples": [
              731
            ]
          }
        },
        "type": "object",
        "required": [
          "name",
          "count"
        ],
        "title": "NameCount"
      },
      "Source": {
        "type": "string",
        "enum": [
          "pln_spklu",
          "open_charge_map",
          "osm"
        ],
        "title": "Source"
      },
      "SourceCount": {
        "properties": {
          "source": {
            "$ref": "#/components/schemas/Source"
          },
          "count": {
            "type": "integer",
            "title": "Count"
          }
        },
        "type": "object",
        "required": [
          "source",
          "count"
        ],
        "title": "SourceCount"
      },
      "Station": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Stable unique id, '<source>-<n>'.",
            "examples": [
              "pln_spklu-1"
            ]
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name",
            "examples": [
              "SPKLU PLN UID JAKARTA RAYA"
            ]
          },
          "source": {
            "$ref": "#/components/schemas/Source",
            "description": "Originating dataset."
          },
          "latitude": {
            "type": "number",
            "maximum": 90.0,
            "minimum": -90.0,
            "title": "Latitude",
            "examples": [
              -6.18039
            ]
          },
          "longitude": {
            "type": "number",
            "maximum": 180.0,
            "minimum": -180.0,
            "title": "Longitude",
            "examples": [
              106.833191
            ]
          },
          "address": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Address",
            "examples": [
              "Jl. M.I. Ridwan Rais No.1, Gambir"
            ]
          },
          "province": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Province",
            "examples": [
              "DKI Jakarta"
            ]
          },
          "city": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "City",
            "examples": [
              "Kota ADM Jakarta Pusat"
            ]
          },
          "operator": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Operator",
            "examples": [
              "PLN"
            ]
          },
          "power_kw": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Power Kw",
            "description": "Peak power (kW).",
            "examples": [
              22.0
            ]
          },
          "charge_type": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Charge Type",
            "description": "slow / medium / fast where known.",
            "examples": [
              "medium"
            ]
          },
          "connectors": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Connectors",
            "description": "Number of connectors/points.",
            "examples": [
              2
            ]
          },
          "status": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Status",
            "description": "Operational status if reported.",
            "examples": [
              "operational"
            ]
          },
          "date_verified": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Date Verified",
            "description": "ISO timestamp last verified (OCM)."
          },
          "distance_km": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Distance Km",
            "description": "Set only on /nearby results.",
            "examples": [
              1.42
            ]
          }
        },
        "type": "object",
        "required": [
          "id",
          "source",
          "latitude",
          "longitude"
        ],
        "title": "Station"
      },
      "StationList": {
        "properties": {
          "total": {
            "type": "integer",
            "title": "Total",
            "description": "Total matching records (before pagination).",
            "examples": [
              1142
            ]
          },
          "limit": {
            "type": "integer",
            "title": "Limit",
            "examples": [
              100
            ]
          },
          "offset": {
            "type": "integer",
            "title": "Offset",
            "examples": [
              0
            ]
          },
          "items": {
            "items": {
              "$ref": "#/components/schemas/Station"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "total",
          "limit",
          "offset",
          "items"
        ],
        "title": "StationList"
      },
      "Stats": {
        "properties": {
          "total": {
            "type": "integer",
            "title": "Total",
            "examples": [
              3569
            ]
          },
          "by_source": {
            "items": {
              "$ref": "#/components/schemas/SourceCount"
            },
            "type": "array",
            "title": "By Source"
          },
          "by_province": {
            "items": {
              "$ref": "#/components/schemas/NameCount"
            },
            "type": "array",
            "title": "By Province"
          },
          "by_charge_type": {
            "items": {
              "$ref": "#/components/schemas/NameCount"
            },
            "type": "array",
            "title": "By Charge Type"
          },
          "with_power_kw": {
            "type": "integer",
            "title": "With Power Kw",
            "description": "Records that have a known power rating."
          },
          "power_kw_min": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Power Kw Min"
          },
          "power_kw_max": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
